---
layout: null
# Custom sitemap replacing jekyll-sitemap plugin.
# - Posts: only status "published" or "placeholder" (draft/unpublished are
#   excluded AND carry a noindex robots meta — keep the two in sync).
# - Papers: every PDF in assets/papers/ is listed too — Google indexes PDFs,
#   and the author wants them found. lastmod comes from _data/papers.yml.
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd"
        xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% comment %} Only real content pages: their permalinks end in "/". This skips
  utility files (404.html, offline.html, search.json, sw.js, sitemap.xml,
  site.webmanifest, feed.xml, robots.txt). {% endcomment %}
  {% for page in site.pages %}{% assign last_char = page.url | slice: -1 %}{% if page.url and last_char == "/" and page.sitemap != false %}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
    {% if page.date %}<lastmod>{{ page.date | date_to_xmlschema }}</lastmod>{% endif %}
    {% if page.url == "/" %}<changefreq>weekly</changefreq><priority>1.0</priority>
    {% elsif page.url == "/articles/" %}<changefreq>weekly</changefreq><priority>0.9</priority>
    {% elsif page.url == "/papers/" or page.url == "/projects/" %}<changefreq>weekly</changefreq><priority>0.8</priority>
    {% elsif page.url == "/categories/" or page.url == "/tags/" %}<changefreq>weekly</changefreq><priority>0.6</priority>
    {% elsif page.url == "/about/" %}<changefreq>monthly</changefreq><priority>0.5</priority>
    {% else %}<changefreq>yearly</changefreq><priority>0.3</priority>
    {% endif %}
  </url>
  {% endif %}{% endfor %}
  {% for post in site.posts %}{% if post.status == "published" or post.status == "placeholder" %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endif %}{% endfor %}
  {% comment %} Paper landing pages (the canonical, indexable entity per paper).
  The thin reader shell (/papers/<slug>/read/) is noindex and skipped here. {% endcomment %}
  {% assign paper_landings = site.papers | where_exp: "d", "d.layout != 'paper-reader'" %}
  {% for doc in paper_landings %}{% assign meta = site.data.papers[doc.pdf] %}
  <url>
    <loc>{{ doc.url | absolute_url | xml_escape }}</loc>
    {% if meta.date %}<lastmod>{{ meta.date | date: "%Y-%m-%d" }}</lastmod>{% endif %}
    <changefreq>yearly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}
  {% comment %} Papers: filenames may contain spaces, so the path must be
  URI-escaped to be a valid sitemap <loc>. {% endcomment %}
  {% assign paper_files = site.static_files | where_exp: "f", "f.path contains '/assets/papers/'" | sort: "name" %}
  {% for file in paper_files %}{% assign ext = file.extname | downcase %}{% if ext == ".pdf" %}{% assign meta = site.data.papers[file.name] %}
  <url>
    <loc>{{ file.path | uri_escape | absolute_url | xml_escape }}</loc>
    {% if meta.date %}<lastmod>{{ meta.date | date: "%Y-%m-%d" }}</lastmod>{% endif %}
    <changefreq>yearly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endif %}{% endfor %}
</urlset>
